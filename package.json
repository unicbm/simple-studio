{
  "name": "simple-studio",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "api": "cargo run --manifest-path src-tauri/Cargo.toml",
    "test": "vitest run"
  },
  "dependencies": {
    "dompurify": "^3.3.0",
    "marked": "^16.4.1",
    "svelte": "^5.39.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@tsconfig/svelte": "^5.0.5",
    "jsdom": "^29.0.2",
    "svelte-check": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
